{
  "name": "openapi-to-mcp",
  "version": "1.0.0",
  "description": "Generate a minimal, Vercel-ready MCP server from an OpenAPI spec.",
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file=.env src/dev-server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "openapi-types": "^12.1.3",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.3.0",
    "tsx": "^4.19.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "packageManager": "pnpm@10.33.0"
}
