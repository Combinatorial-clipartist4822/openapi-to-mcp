# Required: URL or file path to your OpenAPI spec (YAML or JSON)
OPENAPI_SPEC_URL=https://api.example.com/openapi.yaml

# Optional: Override the API base URL (defaults to servers[0].url from the spec)
# API_BASE_URL=https://api.example.com

# Optional: Override the MCP server name (defaults to info.title from the spec)
# MCP_SERVER_NAME=My API

# Optional: Local dev server port (default: 3000)
# PORT=3000
