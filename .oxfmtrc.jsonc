{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "printWidth": 80,
  "semi": true,
  "tabWidth": 2,
  "useTabs": false,
  "arrowParens": "always",
  "sortImports": {
    "groups": ["builtin", "external", ["parent", "sibling", "index"]],
    "newlinesBetween": true,
    "order": "asc",
  },
  "ignorePatterns": ["node_modules", "dist", "*.md"],
}
